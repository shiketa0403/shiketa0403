# X 予約投稿 .env サンプル
# このファイルを .env にコピーして、値を埋めてください
# .env は .gitignore で除外されているのでコミットされません

# === X (Twitter) Cookie ===
# Chrome / Firefox で X (https://x.com) にログインした状態で
# F12 (DevTools) -> Application (Storage) -> Cookies -> https://x.com
# から以下の2つの値をコピーする
X_AUTH_TOKEN=ここに auth_token の値を貼る
X_CT0=ここに ct0 の値を貼る

# === Google Sheets (x_schedule.py を使う場合) ===
# スプレッドシートの URL の /d/ と /edit の間の文字列
GSPREAD_SHEET_ID=

# Service Account JSON ファイルへのパス
# リポジトリ直下に service_account.json を置くなら、デフォルト値のままでOK
GSPREAD_SERVICE_ACCOUNT_FILE=service_account.json

# シート名（複数シートがある場合のみ。空欄なら 1 枚目）
GSPREAD_WORKSHEET_NAME=
